# ── Otomato ───────────────────────────────────────────────────────────────────
# Your API key from https://app.otomato.xyz/settings
OTOMATO_API_KEY=

# Otomato API base URL — leave commented unless you're on a staging instance
# OTOMATO_API_URL=https://api.otomato.xyz/api

# ── Relay webhook ─────────────────────────────────────────────────────────────
# Full public URL of your hosted relay, WITHOUT a trailing slash.
# Examples:
#   Railway:  https://thatsrekt-production.up.railway.app
#   ngrok:    https://abcd-1234.ngrok-free.app
# The workflow will POST to ${WEBHOOK_BASE_URL}/detect
WEBHOOK_BASE_URL=

# Bearer token the relay expects in the Authorization header.
# Must match the RELAY_PROVIDER_TOKEN (or equivalent) set on your relay instance.
# Treat this as a shared secret — do not commit it.
WEBHOOK_TOKEN=

# Chain identifier the relay is configured for.
# Common values: ethereum, base, anvil-eth (local dev)
WEBHOOK_CHAIN=ethereum
