# GraphQL endpoint the frontend queries.
# Default for local dev is the indexer's docker-compose api service:
#   cd ../indexer && docker compose up -d --build
# Production deploys (e.g. IPFS) should point at a publicly-reachable
# squid GraphQL endpoint.
VITE_GRAPHQL_ENDPOINT=http://localhost:4350/graphql

# When true, the frontend ignores VITE_GRAPHQL_ENDPOINT and serves a built-in
# dummy dataset (see src/lib/mock.ts). Useful for first-run UI inspection,
# screenshots, and design iteration without spinning up the indexer stack.
# A persistent banner is shown across all pages while this is on.
VITE_USE_MOCK_DATA=true
